          <bpmn:incoming>Flow_InventoryTask</bpmn:incoming>
          <bpmn:outgoing>Flow_CompareData</bpmn:outgoing>
        </bpmn:task>
        <bpmn:serviceTask id="Activity_CompareData" name="Сравнение данных">
          <bpmn:incoming>Flow_CompareData</bpmn:incoming>
          <bpmn:outgoing>Flow_CompleteInventory</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:serviceTask id="Activity_CompleteInventory" name="Завершение инвентаризации">
          <bpmn:incoming>Flow_CompleteInventory</bpmn:incoming>
          <bpmn:outgoing>Flow_InventoryEnd</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="Event_InventoryEnd">
          <bpmn:incoming>Flow_InventoryEnd</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_StartInventory" sourceRef="Event_InventoryStart" targetRef="Activity_StartInventory" />
        <bpmn:sequenceFlow id="Flow_InventoryTask" sourceRef="Activity_StartInventory" targetRef="Activity_InventoryTask" />
        <bpmn:sequenceFlow id="Flow_CompareData" sourceRef="Activity_InventoryTask" targetRef="Activity_CompareData" />
        <bpmn:sequenceFlow id="Flow_CompleteInventory" sourceRef="Activity_CompareData" targetRef="Activity_CompleteInventory" />
        <bpmn:sequenceFlow id="Flow_InventoryEnd" sourceRef="Activity_CompleteInventory" targetRef="Event_InventoryEnd" />
      </bpmn:subProcess>
      <bpmn:callActivity id="Activity_WMS_InventoryLogin" name="WMS Зайти в систему" calledElement="WMS.00.00.01.05">
        <bpmn:outgoing>Flow_InventoryStart</bpmn:outgoing>
      </bpmn:callActivity>
      <bpmn:sequenceFlow id="Flow_InventoryStart" sourceRef="Activity_WMS_InventoryLogin" targetRef="Activity_WMS_Inventory" />
    </bpmn:subProcess>
    <bpmn:endEvent id="EndEvent_Process">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToReceipt" sourceRef="StartEvent_Process" targetRef="Activity_Receipt" />
