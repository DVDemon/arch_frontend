      </bpmn:callActivity>
      <bpmn:sequenceFlow id="Flow_ShipmentStart" sourceRef="Activity_WMS_ShipmentLogin" targetRef="Activity_WMS_Shipment" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_Inventory" name="WMS Инвентаризация">
      <bpmn:incoming>Flow_ToInventory</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
      <bpmn:subProcess id="Activity_WMS_Inventory" name="BI Инвентаризация">
        <bpmn:incoming>Flow_InventoryStart</bpmn:incoming>
        <bpmn:startEvent id="Event_InventoryStart">
          <bpmn:outgoing>Flow_StartInventory</bpmn:outgoing>
