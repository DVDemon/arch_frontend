<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_warehouse_operations" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.27.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="Process_WarehouseOperations" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Process">
      <bpmn:outgoing>Flow_ToReceipt</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:subProcess id="Activity_Receipt" name="WMS Приемка товара">
      <bpmn:incoming>Flow_ToReceipt</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPlacement</bpmn:outgoing>
      <bpmn:subProcess id="Activity_WMS_Receipt" name="BI Приемка товара">
        <bpmn:incoming>Flow_ReceiptStart</bpmn:incoming>
        <bpmn:startEvent id="Event_ReceiptStart">
          <bpmn:outgoing>Flow_ReceiptTask</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:task id="Activity_ReceiptTask" name="Приемка товара на склад">
          <bpmn:incoming>Flow_ReceiptTask</bpmn:incoming>
          <bpmn:outgoing>Flow_ValidateReceipt</bpmn:outgoing>
        </bpmn:task>
        <bpmn:serviceTask id="Activity_ValidateReceipt" name="Валидация товара">
          <bpmn:incoming>Flow_ValidateReceipt</bpmn:incoming>
          <bpmn:outgoing>Flow_UpdateStock</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:serviceTask id="Activity_UpdateStock" name="Обновление остатков">
          <bpmn:incoming>Flow_UpdateStock</bpmn:incoming>
          <bpmn:outgoing>Flow_ReceiptEnd</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="Event_ReceiptEnd">
          <bpmn:incoming>Flow_ReceiptEnd</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_ReceiptTask" sourceRef="Event_ReceiptStart" targetRef="Activity_ReceiptTask" />
        <bpmn:sequenceFlow id="Flow_ValidateReceipt" sourceRef="Activity_ReceiptTask" targetRef="Activity_ValidateReceipt" />
        <bpmn:sequenceFlow id="Flow_UpdateStock" sourceRef="Activity_ValidateReceipt" targetRef="Activity_UpdateStock" />
        <bpmn:sequenceFlow id="Flow_ReceiptEnd" sourceRef="Activity_UpdateStock" targetRef="Event_ReceiptEnd" />
      </bpmn:subProcess>
      <bpmn:callActivity id="Activity_WMS_Login" name="WMS Зайти в систему" calledElement="WMS.00.00.01.01">
        <bpmn:outgoing>Flow_ReceiptStart</bpmn:outgoing>
      </bpmn:callActivity>
      <bpmn:sequenceFlow id="Flow_ReceiptStart" sourceRef="Activity_WMS_Login" targetRef="Activity_WMS_Receipt" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_Placement" name="WMS Размещение товара">
      <bpmn:incoming>Flow_ToPlacement</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPicking</bpmn:outgoing>
      <bpmn:subProcess id="Activity_WMS_Placement" name="BI Размещение товара">
        <bpmn:incoming>Flow_PlacementStart</bpmn:incoming>
        <bpmn:startEvent id="Event_PlacementStart">
          <bpmn:outgoing>Flow_DetermineLocation</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:serviceTask id="Activity_DetermineLocation" name="Определение места размещения">
          <bpmn:incoming>Flow_DetermineLocation</bpmn:incoming>
          <bpmn:outgoing>Flow_PlacementTask</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:task id="Activity_PlacementTask" name="Размещение товара на складе">
          <bpmn:incoming>Flow_PlacementTask</bpmn:incoming>
          <bpmn:outgoing>Flow_UpdateLocation</bpmn:outgoing>
        </bpmn:task>
        <bpmn:serviceTask id="Activity_UpdateLocation" name="Обновление местоположения">
          <bpmn:incoming>Flow_UpdateLocation</bpmn:incoming>
          <bpmn:outgoing>Flow_PlacementEnd</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="Event_PlacementEnd">
          <bpmn:incoming>Flow_PlacementEnd</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_DetermineLocation" sourceRef="Event_PlacementStart" targetRef="Activity_DetermineLocation" />
        <bpmn:sequenceFlow id="Flow_PlacementTask" sourceRef="Activity_DetermineLocation" targetRef="Activity_PlacementTask" />
        <bpmn:sequenceFlow id="Flow_UpdateLocation" sourceRef="Activity_PlacementTask" targetRef="Activity_UpdateLocation" />
        <bpmn:sequenceFlow id="Flow_PlacementEnd" sourceRef="Activity_UpdateLocation" targetRef="Event_PlacementEnd" />
      </bpmn:subProcess>
      <bpmn:callActivity id="Activity_WMS_PlacementLogin" name="WMS Зайти в систему" calledElement="WMS.00.00.01.02">
        <bpmn:outgoing>Flow_PlacementStart</bpmn:outgoing>
      </bpmn:callActivity>
      <bpmn:sequenceFlow id="Flow_PlacementStart" sourceRef="Activity_WMS_PlacementLogin" targetRef="Activity_WMS_Placement" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_Picking" name="WMS Отбор товара">
      <bpmn:incoming>Flow_ToPicking</bpmn:incoming>
      <bpmn:outgoing>Flow_ToShipment</bpmn:outgoing>
      <bpmn:subProcess id="Activity_WMS_Picking" name="BI Отбор товара">
        <bpmn:incoming>Flow_PickingStart</bpmn:incoming>
        <bpmn:startEvent id="Event_PickingStart">
          <bpmn:outgoing>Flow_OptimizeRoute</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:serviceTask id="Activity_OptimizeRoute" name="Оптимизация маршрута отбора">
          <bpmn:incoming>Flow_OptimizeRoute</bpmn:incoming>
          <bpmn:outgoing>Flow_PickingTask</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:task id="Activity_PickingTask" name="Отбор товара со склада">
          <bpmn:incoming>Flow_PickingTask</bpmn:incoming>
          <bpmn:outgoing>Flow_ConfirmPicking</bpmn:outgoing>
        </bpmn:task>
        <bpmn:serviceTask id="Activity_ConfirmPicking" name="Подтверждение отбора">
          <bpmn:incoming>Flow_ConfirmPicking</bpmn:incoming>
          <bpmn:outgoing>Flow_PickingEnd</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="Event_PickingEnd">
          <bpmn:incoming>Flow_PickingEnd</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_OptimizeRoute" sourceRef="Event_PickingStart" targetRef="Activity_OptimizeRoute" />
        <bpmn:sequenceFlow id="Flow_PickingTask" sourceRef="Activity_OptimizeRoute" targetRef="Activity_PickingTask" />
        <bpmn:sequenceFlow id="Flow_ConfirmPicking" sourceRef="Activity_PickingTask" targetRef="Activity_ConfirmPicking" />
        <bpmn:sequenceFlow id="Flow_PickingEnd" sourceRef="Activity_ConfirmPicking" targetRef="Event_PickingEnd" />
      </bpmn:subProcess>
      <bpmn:callActivity id="Activity_WMS_PickingLogin" name="WMS Зайти в систему" calledElement="WMS.00.00.01.03">
        <bpmn:outgoing>Flow_PickingStart</bpmn:outgoing>
      </bpmn:callActivity>
      <bpmn:sequenceFlow id="Flow_PickingStart" sourceRef="Activity_WMS_PickingLogin" targetRef="Activity_WMS_Picking" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_Shipment" name="WMS Отгрузка товара">
      <bpmn:incoming>Flow_ToShipment</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInventory</bpmn:outgoing>
      <bpmn:subProcess id="Activity_WMS_Shipment" name="BI Отгрузка товара">
        <bpmn:incoming>Flow_ShipmentStart</bpmn:incoming>
        <bpmn:startEvent id="Event_ShipmentStart">
          <bpmn:outgoing>Flow_PrepareShipment</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:serviceTask id="Activity_PrepareShipment" name="Подготовка отгрузки">
          <bpmn:incoming>Flow_PrepareShipment</bpmn:incoming>
          <bpmn:outgoing>Flow_ShipmentTask</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:task id="Activity_ShipmentTask" name="Отгрузка товара">
          <bpmn:incoming>Flow_ShipmentTask</bpmn:incoming>
          <bpmn:outgoing>Flow_UpdateStockShipment</bpmn:outgoing>
        </bpmn:task>
        <bpmn:serviceTask id="Activity_UpdateStockShipment" name="Списание остатков">
          <bpmn:incoming>Flow_UpdateStockShipment</bpmn:incoming>
          <bpmn:outgoing>Flow_CreateDocuments</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:serviceTask id="Activity_CreateDocuments" name="Создание документов">
          <bpmn:incoming>Flow_CreateDocuments</bpmn:incoming>
          <bpmn:outgoing>Flow_ShipmentEnd</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="Event_ShipmentEnd">
          <bpmn:incoming>Flow_ShipmentEnd</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_PrepareShipment" sourceRef="Event_ShipmentStart" targetRef="Activity_PrepareShipment" />
        <bpmn:sequenceFlow id="Flow_ShipmentTask" sourceRef="Activity_PrepareShipment" targetRef="Activity_ShipmentTask" />
        <bpmn:sequenceFlow id="Flow_UpdateStockShipment" sourceRef="Activity_ShipmentTask" targetRef="Activity_UpdateStockShipment" />
        <bpmn:sequenceFlow id="Flow_CreateDocuments" sourceRef="Activity_UpdateStockShipment" targetRef="Activity_CreateDocuments" />
        <bpmn:sequenceFlow id="Flow_ShipmentEnd" sourceRef="Activity_CreateDocuments" targetRef="Event_ShipmentEnd" />
      </bpmn:subProcess>
      <bpmn:callActivity id="Activity_WMS_ShipmentLogin" name="WMS Зайти в систему" calledElement="WMS.00.00.01.04">
