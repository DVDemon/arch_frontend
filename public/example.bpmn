    <bpmn:sequenceFlow id="Flow_ToInventory" sourceRef="Activity_Shipment" targetRef="Activity_Inventory" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Activity_Inventory" targetRef="EndEvent_Process" />
